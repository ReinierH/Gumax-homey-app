{
  "name": {
    "en": "Gumax Sunshade",
    "nl": "Gumax Zonwering"
  },
  "class": "blinds",
  "capabilities": ["windowcoverings_state"],
  "platforms": ["local"],
  "connectivity": ["rf433"],
  "images": {
    "small": "/drivers/gumax_sunshade/assets/images/small.png",
    "large": "/drivers/gumax_sunshade/assets/images/large.png",
    "xlarge": "/drivers/gumax_sunshade/assets/images/xlarge.png"
  },
  "pair": [
    {
      "id": "learn",
      "navigation": {
        "next": "list_devices"
      }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "flow": {
    "actions": [
      {
        "id": "shade_up",
        "title": {
          "en": "Move Up",
          "nl": "Omhoog"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=gumax_sunshade"
          }
        ]
      },
      {
        "id": "shade_stop",
        "title": {
          "en": "Stop",
          "nl": "Stop"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=gumax_sunshade"
          }
        ]
      },
      {
        "id": "shade_down",
        "title": {
          "en": "Move Down",
          "nl": "Omlaag"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=gumax_sunshade"
          }
        ]
      }
    ]
  }
}
